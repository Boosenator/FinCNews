# Sanity — знайти на sanity.io/manage → твій проєкт → Settings → API
NEXT_PUBLIC_SANITY_PROJECT_ID=xxxxxxxxxxxxxxxx
NEXT_PUBLIC_SANITY_DATASET=production

# Sanity write token (Settings → API → Tokens → Editor)
SANITY_TOKEN=skXxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Секрет для /api/publish (будь-який рядок — треба вказати і в n8n)
N8N_SECRET=change_me_random_string_here

# URL сайту
NEXT_PUBLIC_BASE_URL=http://localhost:3000
